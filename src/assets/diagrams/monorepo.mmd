flowchart LR

subgraph R["single Git repository"]
  direction TB

  subgraph LIB["Shared Libraries (libs/)"]
    direction TB
    L1["libs/common"]
    L2["libs/lib-a"]
    L3["libs/lib-b"]
  end

  REF[["editable / symlinked dependency<br>(uv workspace link)"]]

  subgraph WS["uv Workspaces"]
